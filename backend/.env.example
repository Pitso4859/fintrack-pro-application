# FinTrack Pro — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ---- Database ----
DATABASE_URL=jdbc:postgresql://localhost:5432/fintrack
DATABASE_USERNAME=fintrack
DATABASE_PASSWORD=your_secure_password_here
DATABASE_DRIVER=org.postgresql.Driver
JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ---- JWT ----
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_hex_characters_long
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ---- Gemini AI ----
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com

# ---- Spring ----
SPRING_PROFILES_ACTIVE=prod
PORT=8080
