<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="003-create-transactions" author="fintrack">
        <createTable tableName="transactions">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(18,2)">
                <constraints nullable="false"/>
            </column>
            <column name="vat_amount" type="DECIMAL(18,2)" defaultValueNumeric="0.00">
                <constraints nullable="false"/>
            </column>
            <column name="net_amount" type="DECIMAL(18,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(3)" defaultValue="ZAR">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="reference_number" type="VARCHAR(100)"/>
            <column name="supplier_name" type="VARCHAR(255)"/>
            <column name="customer_name" type="VARCHAR(255)"/>
            <column name="account_id" type="VARCHAR(50)"/>
            <column name="account_code" type="VARCHAR(20)"/>
            <column name="transaction_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="invoice_image_url" type="VARCHAR(512)"/>
            <column name="ai_processed" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="VARCHAR(1000)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="transactions" indexName="idx_tx_user">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="transactions" indexName="idx_tx_date">
            <column name="transaction_date"/>
        </createIndex>
        <createIndex tableName="transactions" indexName="idx_tx_type">
            <column name="type"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
