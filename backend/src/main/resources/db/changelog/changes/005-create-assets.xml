<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="005-create-assets" author="fintrack">
        <createTable tableName="assets">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(100)"/>
            <column name="purchase_date" type="DATE"/>
            <column name="purchase_price" type="DECIMAL(15,2)" defaultValueNumeric="0.00"/>
            <column name="supplier_name" type="VARCHAR(255)"/>
            <column name="warranty_expiry" type="DATE"/>
            <column name="serial_number" type="VARCHAR(100)"/>
            <column name="location" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE"/>
            <column name="document_data" type="TEXT"/>
            <column name="transaction_id" type="VARCHAR(36)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="user_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="assets" indexName="idx_assets_user">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
