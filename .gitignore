# ============================================================
# FinTrack Pro — .gitignore
# ============================================================

# Environment / secrets — NEVER commit these
.env
.env.local
.env.production
*.env

# Java / Maven
target/
*.class
*.jar
*.war
*.ear
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Node / Frontend
node_modules/
dist/
frontend/.vite/
*.tsbuildinfo

# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Logs
*.log
logs/

# Test coverage
htmlcov/
coverage/
jacoco.exec

# OS
.DS_Store
desktop.ini
